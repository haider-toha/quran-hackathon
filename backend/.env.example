# Copy to .env and fill in real values. Never commit .env.
# `make gen-secret` produces a random base64 value suitable for SECRET_KEY-style vars.

# Human-readable app name. Surfaces in OpenAPI docs and logs.
APP_NAME="Quran Hackathon API"

# Toggles verbose logging + FastAPI debug responses. Never enable in production.
DEBUG=false

# Anthropic API key — required only if you're using Anthropic as the LLM provider.
# Swap or add provider-specific keys (OPENAI_API_KEY, etc.) if you change providers.
ANTHROPIC_API_KEY=sk-ant-...

# JSON list of allowed origins for CORS. Pydantic settings parses this directly.
CORS_ORIGINS=["http://localhost:3000"]
