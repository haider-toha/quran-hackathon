# Copy to .env and fill in real values. Never commit .env.
# `make gen-secret` produces a random base64 value suitable for SECRET_KEY-style vars.

# Human-readable app name. Surfaces in OpenAPI docs and logs.
APP_NAME="Quran Hackathon API"

# Toggles verbose logging + FastAPI debug responses. Never enable in production.
DEBUG=false

# Anthropic API key — required only if you're using Anthropic as the LLM provider.
# Swap or add provider-specific keys (OPENAI_API_KEY, etc.) if you change providers.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used for text-embedding-3-small (tafsir RAG embeddings).
OPENAI_API_KEY=sk-...

# JSON list of allowed origins for CORS. Pydantic settings parses this directly.
CORS_ORIGINS=["http://localhost:3000"]

# Supabase
# Project URL — `https://<project-ref>.supabase.co`
SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable (anon) key — exposed to browsers; safe to embed in frontend bundle
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret (service_role) key — backend ONLY; bypasses RLS. Treat like a password.
SUPABASE_SECRET_KEY=sb_secret_...
